# ═══════════════════════════════════════════════════════════════
#  WANTED — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ═══════════════════════════════════════════════════════════════

# ─── SERVEUR ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# URL du frontend (pour CORS et liens emails)
FRONTEND_URL=http://localhost:5500
# URL du backend (pour les webhooks Fapshi)
BACKEND_URL=http://localhost:5000

# ─── BASE DE DONNÉES PostgreSQL ────────────────────────────────
# Railway fournit cette URL automatiquement
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/wanted_db

# ─── JWT ───────────────────────────────────────────────────────
# Générez une clé aléatoire longue (min 64 caractères)
JWT_SECRET=changez_moi_avec_une_cle_tres_longue_et_aleatoire_minimum_64_chars_abc123
JWT_EXPIRES_IN=7d

# ─── COMPTE ADMIN PAR DÉFAUT ───────────────────────────────────
# Créé automatiquement au premier démarrage
# ⚠️ CHANGEZ CES VALEURS avant la mise en production !
ADMIN_EMAIL=admin@wanted.app
ADMIN_PASSWORD=Admin@2024!
ADMIN_NAME=Administrateur

# ─── RESEND (emails transactionnels) ───────────────────────────
# Créez un compte gratuit sur https://resend.com
# Plan gratuit : 3 000 emails/mois, 100/jour
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@votredomaine.com

# ─── FAPSHI (paiements Orange Money / MTN) ─────────────────────
# Créez un compte marchand sur https://fapshi.com
# En mode development, les paiements sont simulés automatiquement
FAPSHI_API_USER=votre_api_user_fapshi
FAPSHI_API_KEY=votre_api_key_fapshi
FAPSHI_BASE_URL=https://live.fapshi.com

# ─── UPLOADS ───────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ─── COINS (valeurs par action) ────────────────────────────────
# 1 coin = 1 XAF par défaut (configurable dans l'admin)
COIN_VALUE_XAF=1
COINS_PER_REPOST=10
COINS_PER_SHARE=5
COINS_PER_POST=20
COINS_PER_WITNESS=50
COINS_PER_FOUND=200
COINS_WELCOME=100
MIN_WITHDRAW_COINS=500
